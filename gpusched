#!/usr/bin/env python3
"""
Repository-local launcher for unified gpuscheduler CLI.
"""

from pathlib import Path
import sys


def _bootstrapPath() -> None:
    repoRoot = Path(__file__).resolve().parent
    srcPath = repoRoot / "src"
    if str(srcPath) not in sys.path:
        sys.path.insert(0, str(srcPath))


def main() -> int:
    _bootstrapPath()
    from gpuscheduler.cli import main as cliMain

    return int(cliMain(sys.argv[1:]) or 0)


if __name__ == "__main__":
    raise SystemExit(main())
